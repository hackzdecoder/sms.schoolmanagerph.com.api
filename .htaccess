# ============================================================
# FRONTEND (React/SPA) ROUTING
# ============================================================

# File: /public_html/.htaccess

RewriteEngine On

# If the request is for a file that exists in /app/dist, serve it from /app/dist
RewriteCond %{DOCUMENT_ROOT}/app/dist%{REQUEST_URI} -f
RewriteRule ^(.*)$ /app/dist/$1 [L]

# If the request is for a directory that exists in /app/dist, serve it from /app/dist
RewriteCond %{DOCUMENT_ROOT}/app/dist%{REQUEST_URI} -d
RewriteRule ^(.*)$ /app/dist/$1 [L]

# For everything else, serve index.html from /app/dist (SPA fallback)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /app/dist/index.html [L]



# ============================================================
# BACKEND (Laravel API) ROUTING
# ============================================================

# Redirect all /api/* requests to the backend
RewriteRule ^api/(.*)$ /api/public/index.php/$1 [L]

# OR if your backend is in a different folder, use this:
# RewriteRule ^api/(.*)$ /backend/public/index.php/$1 [L]